# ะฏัะตะนะบะฐ 4: ะขะตััะธัะพะฒะฐะฝะธะต ัะผะพัะธะพะฝะฐะปัะฝะพะน ะผะพะดะตะปะธ
from emotional_model import EmotionalState

# ะกะพะทะดะฐะฝะธะต ัะบะทะตะผะฟะปััะฐ ัะผะพัะธะพะฝะฐะปัะฝะพะน ะผะพะดะตะปะธ
emotional_model = EmotionalState()

print("\n=== ะขะะกะขะะ ะะะะะะ ะญะะะฆะะะะะะฌะะะ ะะะะะะ ===")

# ะขะตััะพะฒัะต ััะฐะทั ะดะปั ะฟัะพะฒะตัะบะธ ัะผะพัะธะพะฝะฐะปัะฝัั ัะตะฐะบัะธะน
test_phrases = [
    "ะฏ ัะฐะบ ัะฐะด ัะตะณะพะดะฝััะฝะธะผ ะฝะพะฒะพัััะผ! ะญัะพ ะฟัะพััะพ ะฟัะตะบัะฐัะฝะพ!",
    "ะะตะฝั ัะฐััััะพะธะปะฐ ััะฐ ัะธััะฐัะธั, ััะฒััะฒัั ัะตะฑั ะฟะพะดะฐะฒะปะตะฝะฝะพ...",
    "ะญัะพั ัะตะปะพะฒะตะบ ะผะตะฝั ะฑะตัะธั, ั ะฒ ััะพััะธ ะพั ะตะณะพ ะฟะพัััะฟะบะฐ!",
    "ะะพััั, ััะพ ะฝะธัะตะณะพ ะฝะต ะฟะพะปััะธััั, ัััะฐัะฝะพ ะฝะฐัะธะฝะฐัั ะฝะพะฒะพะต ะดะตะปะพ.",
    "ะฏ ะดะพะฒะตััั ัะตะฑะต ะธ ัะฒะตัะตะฝ ะฒ ะฝะฐัะตะผ ัะพัััะดะฝะธัะตััะฒะต."
]

for i, phrase in enumerate(test_phrases, 1):
    print(f"\n{i}. ะคัะฐะทะฐ: '{phrase}'")
    emotional_state = emotional_model.update_from_text(phrase)
    print(f"   ะะฐัััะพะตะฝะธะต: {emotional_state['mood']}")
    print(f"   ะะพะผะธะฝะธััััะฐั ัะผะพัะธั: {emotional_state['dominant_emotion']}")
    print(f"   ะะฝัะตะฝัะธะฒะฝะพััั: {emotional_state['dominant_intensity']}")

# ะฏัะตะนะบะฐ 5: ะะฝะฐะปะธะท ะฒะปะธัะฝะธั ะปะธัะฝะพััะธ
print("\n=== ะะะะฏะะะ ะะะงะะะกะขะ ะะ ะญะะะฆะะ ===")
summary = emotional_model.get_emotional_summary()
print(f"ะะฐัะตะณะพัะธั ะฝะฐัััะพะตะฝะธั: {summary['mood_category']}")
print(f"ะญะผะพัะธะพะฝะฐะปัะฝัะน ััะตะฝะด: {summary['emotional_trend']}")
print(f"ะกัะฐะฑะธะปัะฝะพััั: {summary['current_state']['emotional_stability']}")

# ะฏัะตะนะบะฐ 6: ะะธะทัะฐะปะธะทะฐัะธั ัะผะพัะธะพะฝะฐะปัะฝะพะณะพ ัะพััะพัะฝะธั
import matplotlib.pyplot as plt

emotions = summary['current_state']['emotions']
plt.figure(figsize=(10, 6))
plt.bar(emotions.keys(), emotions.values())
plt.title('ะญะผะพัะธะพะฝะฐะปัะฝัะน ะฟัะพัะธะปั ะะปะธัั')
plt.xticks(rotation=45)
plt.ylabel('ะะฝัะตะฝัะธะฒะฝะพััั')
plt.tight_layout()
plt.show()

# ะฏัะตะนะบะฐ 7: ะกะพััะฐะฝะตะฝะธะต ัะตะทัะปััะฐัะพะฒ ัะตััะธัะพะฒะฐะฝะธั
test_results = {
    "test_date": datetime.now().isoformat(),
    "profile_validation": "passed",
    "emotional_model_tests": len(test_phrases),
    "final_emotional_state": summary['current_state'],
    "personality_effects": summary['personality_influence']
}

with open('phase1_test_results.json', 'w') as f:
    json.dump(test_results, f, indent=2, ensure_ascii=False)

print("\n=== ะขะะกะขะะ ะะะะะะ ะคะะะซ 1 ะะะะะ ะจะะะ ===")
print("ะ ะตะทัะปััะฐัั ัะพััะฐะฝะตะฝั ะฒ phase1_test_results.json")